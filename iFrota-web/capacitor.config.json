{
  "appId": "com.ifrota.app",
  "appName": "IFrota",
  "webDir": "www",
  "android": {
    "allowMixedContent": false
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false,
      "androidSpinnerStyle": "small",
      "splashFullScreen": true,
      "splashImmersive": false
    }
  }
}
